PORT=8000
# USE_VERTEX=true  -> Gemini via Vertex AI (bills GCP project, auth via ADC/gcloud)
# USE_VERTEX=false -> Gemini via AI Studio key below (its own prepay billing)
USE_VERTEX=false
GEMINI_VERTEX_FALLBACK_ENABLED=true
GOOGLE_API_KEY=your_google_ai_studio_api_key
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_REGION=us-central1
# Vertex auth on serverless (Boltic): paste the service-account key JSON here as a
# single-line secret. Empty -> Application Default Credentials (gcloud / mounted
# GOOGLE_APPLICATION_CREDENTIALS file / workload identity).
GOOGLE_CREDENTIALS_JSON=
KAILY_API_SECRET=your_kaily_shared_secret
GEMINI_MODEL=gemini-2.0-flash-001
GEMINI_TIMEOUT_SECONDS=45
MAX_IMAGE_SIZE_MB=10
ENVIRONMENT=development
LOG_LEVEL=INFO

# Min AI-generated probability before that signal routes a dispute to an agent.
AI_DETECTION_MIN_CONFIDENCE=0.6

# ---- Image URL fetch (/dispute image_urls) --------------------------------
# Fetch limits for image_urls ingestion. Private/internal networks are blocked
# before fetch to prevent SSRF. Images are downscaled before the model call.
URL_FETCH_TIMEOUT_SECONDS=10
URL_FETCH_MAX_REDIRECTS=3
URL_FETCH_PROCESSING_RETRIES=2
URL_FETCH_PROCESSING_RETRY_DELAY_SECONDS=0.5
URL_FETCH_USER_AGENT=Kaily-ImgRec/1.0
LINK_EVAL_MODEL_MAX_EDGE_PX=1280
LINK_EVAL_MODEL_IMAGE_QUALITY=85
# PixelBin CDN/preprocessing is optional and template-driven because each
# organization can configure URL datasources differently.
PIXELBIN_ENABLED=false
PIXELBIN_URL_TEMPLATE=
PIXELBIN_ALLOW_DIRECT_FALLBACK=true

# ---- Phase 1: durable audit store + object storage ------------------------
# Async Postgres DSN. Empty -> non-durable in-memory store (DEV ONLY; production
# refuses to boot without this). Alembic uses a SYNC driver (see ALEMBIC_URL).
DATABASE_URL=
# Object store for uploaded images: "memory" (dev/test) | "local" | "gcs" (prod).
OBJECT_STORE_PROVIDER=memory
OBJECT_STORE_LOCAL_DIR=/tmp/imgrecog-objects
GCS_BUCKET=
GCS_REGION=asia-south1
# Image retention in days (deletion job wired in Phase 6; pending legal sign-off).
IMAGE_RETENTION_DAYS=90

# ---- Phase 2: reused-image dedup (Redis pHash index) ----------------------
# Empty -> in-memory index (DEV ONLY; production refuses to boot without it).
REDIS_URL=
# Max Hamming distance on the 64-bit dHash to treat two images as the same image
# (0 = byte-identical; higher tolerates re-compression/cropping).
DEDUP_HAMMING_THRESHOLD=10
# Only prior claims within this many days count as duplicates.
DEDUP_WINDOW_DAYS=30

# Alembic migrations run synchronously — use a sync driver here, NOT asyncpg:
#   ALEMBIC_URL=postgresql+psycopg2://user:pass@host:5432/imgrecog
# Run:  ALEMBIC_URL=... alembic upgrade head

# ---- Grocery dispute verification (/dispute) ----
REFUND_AUTO_APPROVE_MAX=500
# Set DISPUTE_ASSIST_MODE=true to launch recommend-only (human confirms every
# decision) — the safe way to go live while you gather labelled data.
DISPUTE_ASSIST_MODE=false
# Categories allowed to auto-act. mrp_abuse omitted by default (OCR risk) — add it
# once it clears the e2e accuracy eval on real photos.
DISPUTE_AUTONOMOUS_CATEGORIES=expiry,wrong_product,damaged
DAIRY_MIN_SHELF_PCT=30
NON_FNV_NEAR_EXPIRY_DAYS=45
DISPUTE_MAX_IMAGES=5
GEMINI_MAX_CONCURRENCY=8
DISPUTE_PROMPT_VERSION=dispute-v1
